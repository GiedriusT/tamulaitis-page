---
import Layout from '../../layouts/Layout.astro';
import ArticleContainer from '../../components/ArticleContainer/ArticleContainer';
import ArticleHeader from '../../components/ArticleHeader/ArticleHeader.tsx';
import ArticleVersion from '../../components/ArticleVersion/ArticleVersion.tsx';
import ArticleImage from '../../components/ArticleImage/ArticleImage.tsx';
import ArticleAnimatedStrip from '../../components/ArticleAnimatedStrip/ArticleAnimatedStrip.tsx';
import ArticleImageGallery from '../../components/ArticleImageGallery/ArticleImageGallery.tsx';
import ArticleCodeblock from '../../components/ArticleCodeblock/ArticleCodeblock.tsx';
import {
  type ProjectMdxInstance,
  getMdxInstanceBySlug,
  getProjectBySlug,
  getProjects,
} from '../../utils/projects';
import { getProjectPageMetadata } from '../../utils/metadata';

export function getStaticPaths() {
  return getProjects(true).map((project) => ({ params: { slug: project.slug } }));
}

const { slug } = Astro.params;

// Load the pre-converted .mdx files from temp folder at root
// Note: import.meta.glob requires string literals, constants are not supported
const modules = import.meta.glob<ProjectMdxInstance>(
  '../../../temp/*/*.mdx',
  { eager: true }
);

const articles = Object.entries(modules).map(([path, module]) => module);

const project = getProjectBySlug(slug);
const markdownInstance = getMdxInstanceBySlug(articles, slug);

if (!project || !markdownInstance) return Astro.redirect('/404', 404);
---

<Layout {...getProjectPageMetadata(project)}>
  <ArticleContainer>
    <markdownInstance.Content components={{ h1: ArticleHeader, ArticleVersion, ArticleImage, ArticleAnimatedStrip, ArticleImageGallery, ArticleCodeblock }} />
  </ArticleContainer>
</Layout>
