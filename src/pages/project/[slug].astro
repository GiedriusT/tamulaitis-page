---
import Layout from '../../layouts/Layout.astro';
import ArticleContainer from '../../components/ArticleContainer/ArticleContainer';
import {
  type ProjectMarkdownFrontmatter,
  getGlobMarkdownInstanceBySlug,
  getProjectBySlug,
  getProjects,
} from '../../utils/projects';
import { getProjectPageMetadata } from '../../utils/metadata';

export function getStaticPaths() {
  return getProjects(true).map((project) => ({ params: { slug: project.slug } }));
}

const { slug } = Astro.params;



const modules = import.meta.glob<{ frontmatter: ProjectMarkdownFrontmatter; default: any }>(
  '../../../public/content/*/*.md',
  { eager: true }
);

const articles = Object.entries(modules).map(([path, module]) => ({
  file: path,
  frontmatter: module.frontmatter,
  Content: module.default,
}));
const project = getProjectBySlug(slug);
const markdownInstance = getGlobMarkdownInstanceBySlug(articles, slug);

if (!project || !markdownInstance) return Astro.redirect('/404', 404);
---

<Layout {...getProjectPageMetadata(project)}>
  <ArticleContainer>
    <markdownInstance.Content />
  </ArticleContainer>
</Layout>
